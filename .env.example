# Supabase — public vars (safe to expose to browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...

# Supabase — server-only (never expose to browser)
# Get from: Supabase dashboard → Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=

# Paystack — server-only
# Get from: dashboard.paystack.com → Settings → API Keys & Webhooks
# Use sk_test_... for test mode, sk_live_... for production
PAYSTACK_SECRET_KEY=

# App base URL — used for Paystack callback redirect
# Production: https://yourdomain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000
